# PostgreSQL
POSTGRES_DB=hypertube
POSTGRES_USER=hypertube
POSTGRES_PASSWORD=

# Backend
DATABASE_URL=postgres://hypertube:PASSWORD@postgres:5432/hypertube
REDIS_URL=redis://redis:6379
JWT_SECRET=
# URL of the frontend (used for OAuth redirect after login; no trailing slash). Must match where the app is served (e.g. 3000 for 42 callback).
FRONTEND_URL=http://localhost:3000

# SMTP (use Mailhog for local dev)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@hypertube.local

# aria2c
ARIA2_RPC_SECRET=

# OAuth - 42 School (must match the redirect URI set in your 42 app on the intranet)
OAUTH_42_CLIENT_ID=
OAUTH_42_CLIENT_SECRET=
# Where 42 redirects the browser after login; frontend runs on 3000 and proxies /api to backend
OAUTH_42_REDIRECT_URI=http://localhost:3000/api/auth/oauth/42/callback

# OMDb API (optional, for IMDB ratings enrichment — get a free key at omdbapi.com)
OMDB_API_KEY=

# OAuth - Google
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback
